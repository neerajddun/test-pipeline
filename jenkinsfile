pipeline {

    agent any 

    stages {
        
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage ('Unit Test') {

            steps {

                sh 'mvn test'
            }
        }

        stage ('Integration Test') {

            steps {

                sh 'mvn verify'
            }
        }

        stage ('Build') {

            steps {

                sh 'mvn clean install'
            }
        }

        stage ('Docker Image') {
            
            steps {
                
                sh '''
    
                docker build -t ${JOB_NAME}:v1.${BUILD_NUMBER} .
                docker image tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}
                docker image tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:latest 

                '''
            }
        }

        stage ('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', passwordVariable: 'DockerPass', usernameVariable: 'DockerName')]) {
                  sh 'echo $DockerPass | docker login -u $DockerName --password-stdin'
                  sh "docker push neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}"
                  sh "neeraj91/${JOB_NAME}:latest"
                }    
            }
        }

        stage ('Deploy') {
            steps{

                sh 'echo Deploy'
            }
        }
    }

    post {

        always {

            cleanWs()
        }
    }
}