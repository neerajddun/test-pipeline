pipeline {

    agent any 

    stages {
        
        stage('Checkout') {

            steps {
                checkout scm 
            }
        }

        stage ('Unit test') {
            steps {
                sh 'mvn test'
            }
        }

        stage ('Integration Test') {
            steps {
                sh 'mvn verify'
            }
        }

        stage ('Build') {
            steps {
                sh 'mvn clean install'
            }
        }
        
        stage('Docker Image') {
            steps {
                sh "docker build -t ${JOB_NAME}:v1.${BUILD_NUMBER} ."
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}"
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:latest"

            }
        }
    }
}

