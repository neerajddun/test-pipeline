pipeline {

    agent any 

    environment {
        ImageRegistry = "883999921903.dkr.ecr.ap-southeast-1.amazonaws.com"
    }

    stages {

        stage('Checkout') {

            steps {

                checkout scm
            }
        }

        stage ('Unit Test') {

            steps {

                sh 'mvn test'
            }
        }

        stage ('Integration Test') {
            
            steps {

                sh 'mvn verify -DskipTests -B'
            }
        }

        stage ('Build') {

            steps {

                sh 'mvn clean install'
            }
        }
        
        stage ('SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {

                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage ('Quality Gate') {
            steps { 
            
             timeout(time: 5, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true

                }
            }
        }

        stage ('Docker Image') {

            steps {

                sh "docker build -t ${JOB_NAME}:v1.${BUILD_NUMBER} . "
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}"
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:latest"
            }
        }

        stage ('Docker push'){
            steps {
              aws ecr get-login-password --region ap-southeast-1 | docker login --username AWS --password-stdin $ImageRegistry
            }
        }

        stage ('Deploy') {
            steps {
                sh 'echo Deploy'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}