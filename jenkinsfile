pipeline {
    agent any 

    stages {
        stage ('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage ('Unit Test') {
            steps {
                sh 'mvn clean test'
            }
        }

        stage ('Integration Test') {
            steps {
                sh 'mvn clean verify'
            }
        }

        stage ('Build') {
            steps {
                sh 'mvn clean install'
            }
        }
    }
}