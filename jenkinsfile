pipeline {

    agent any 

    stages {
        
        stage('Checkout') {

            steps {
                checkout scm 
            }
        }

        stage ('Unit test') {
            steps {
                sh 'mvn test'
            }
        }

        stage ('Integration Test') {
            steps {
                sh 'mvn verify'
            }
        }

        stage ('Build') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage('Quality Gate') {
             steps {
                timeout(time: 5, unit: 'MINUTES') {
                waitForQualityGate abortPipeline: true
                }
            }
        }
        
        stage('Docker Image') {
            steps {
                sh "docker build -t ${JOB_NAME}:v1.${BUILD_NUMBER} ."
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}"
                sh "docker tag ${JOB_NAME}:v1.${BUILD_NUMBER} neeraj91/${JOB_NAME}:latest"

            }
        }
        
       stage('Docker Push') {
         steps {
              withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', passwordVariable: 'DockerPasswd', usernameVariable: 'DockerName')]) {
              sh 'echo $DockerPasswd | docker login -u $DockerName --password-stdin'
              sh "docker push neeraj91/${JOB_NAME}:v1.${BUILD_NUMBER}"
              sh "docker push neeraj91/${JOB_NAME}:latest"
              sh 'docker logout'            
              }
            }
        }
    }
}

